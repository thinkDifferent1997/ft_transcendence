# ========================================================================== #
#   ft_transcendence — environment template									 #
#																			 #
#   Copy this file to '.env' (or run 'make env') and replace				 #
#   every placeholder. The .env file is gitignored.							 #
#																			 #
#   Never commit real secrets. Never reuse these defaults					 #
#   for any deployment that is reachable from the internet.					 #
# ========================================================================== #


# ------------------------------------------------------------
#   PostgreSQL
#   Used by the postgres container to initialize the database
#   on first boot, and by the backend to connect to it.
# ------------------------------------------------------------
POSTGRES_USER=ft_user
POSTGRES_PASSWORD=replace_me_with_a_strong_password
POSTGRES_DB=ft_transcendence

# Hostname 'postgres' resolves inside the Docker network to the
# postgres service. Port 5432 is the container-internal port,
# not exposed to the host.
DATABASE_URL=postgresql://ft_user:replace_me_with_a_strong_password@postgres:5432/ft_transcendence


# ------------------------------------------------------------
#   Backend (NestJS)
# ------------------------------------------------------------
NODE_ENV=production
BACKEND_PORT=3000

# Secret used to sign JWTs. Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d
# Lifetime of the short-lived token issued between the first factor and
# the 2FA challenge. Keep it short.
JWT_2FA_PENDING_EXPIRES_IN=5m


# ------------------------------------------------------------
#   Frontend
#   Vite injects variables prefixed with VITE_ at build time.
#   The frontend talks to the backend through nginx, so the
#   base URL is the public origin, not the backend container.
# ------------------------------------------------------------
VITE_API_BASE_URL=https://localhost/api
VITE_WS_BASE_URL=wss://localhost/ws


# ------------------------------------------------------------
#   Nginx / TLS
#   Self-signed certs live in nginx/certs/ and are generated
#   by 'make certs'. No secrets here, but documenting the
#   expected paths is useful.
# ------------------------------------------------------------
TLS_CERT_PATH=/etc/nginx/certs/selfsigned.crt
TLS_KEY_PATH=/etc/nginx/certs/selfsigned.key

# ------------------------------------------------------------
#   42 OAUTH API KEYS
#   The real keys should never be pushed
#   Do NOT fill credentials here,
#   copy this section to the .env and fill with values
# ------------------------------------------------------------

FORTYTWO_CLIENT_ID=replace_me_with_your_42_uid
FORTYTWO_CLIENT_SECRET=replace_me_with_your_42_secret


# ------------------------------------------------------------
#   Github API KEYS
#   The real keys should never be pushed
#   Do NOT fill credentials here,
#   copy this section to the .env and fill with values
# ------------------------------------------------------------

GITHUB_CLIENT_ID=replace_me_with_your_github_client_id
GITHUB_CLIENT_SECRET=replace_me_with_your_github_client_secret

#
#   Monitoring (Grafana)
#
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace_me_with_a_strong_password



# Nginx host HTTPS port. Leave unset to use 443 (Docker default).
# Rootless engines (podman at 42) cannot bind privileged ports (<1024):
# uncomment the line below and browse https://localhost:8443 instead.
# AT 42 - PODMAN:
#HTTPS_PORT=8443


